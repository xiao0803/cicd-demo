{
  "title": "cicd-demo",
  "uid": "cicd-demo",
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Up",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "up{job=\"cicd-demo\"}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP req/s by URI",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 8 },
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{job=\"cicd-demo\"}[1m]))",
          "refId": "A",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "P95 latency (s)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket{job=\"cicd-demo\"}[5m])))",
          "refId": "A",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM heap used (bytes)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (area) (jvm_memory_used_bytes{job=\"cicd-demo\"})",
          "refId": "A",
          "legendFormat": "{{area}}"
        }
      ]
    }
  ]
}
